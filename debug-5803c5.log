asure","tag":"PRE","className":"","codeClass":"language-java","textLen":39,"newlineCount":0,"outerSnippet":"<pre contenteditable=\"false\" data-raw-code=\"List&lt;String&gt; names = new ArrayList&lt;&gt;();\" data-code-lang=\"java\"><code class=\"language-java\" data-highlighted=\"yes\">List&lt;String&gt; names = new"}]},"hypothesisId":"A,E","runId":"post-fix"}
