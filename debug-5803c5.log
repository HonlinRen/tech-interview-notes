","tag":"PRE","className":"","codeClass":"language-java","textLen":86,"newlineCount":3,"outerSnippet":"<pre contenteditable=\"false\" data-raw-code=\"List&lt;String&gt; list = new ArrayList&lt;&gt;();\nlist.add(&quot;hello&quot;);\n\nString value = list.get(0);\" data-code-lang=\"java\"><code class=\"language-ja"}]},"hypothesisId":"A,E","runId":"post-fix"}
