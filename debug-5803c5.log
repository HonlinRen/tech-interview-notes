{"timestamp":1782138188682,"sessionId":"ce29c0","location":"content-editor.js:savePage:before-repair","message":"blocks before repair","data":{"sectionId":"property-decorator","blocks":[{"label":"property-decorator","tag":"P","className":"","codeClass":"","textLen":8,"newlineCount":0,"outerSnippet":"<p><code>property</code> 把方法包装成属性访问形式，可配合 getter、setter、deleter 做校验和封装。</p>"},{"label":"property-decorator","tag":"PRE","className":"","codeClass":"language-python hljs","textLen":267,"newlineCount":12,"outerSnippet":"<pre contenteditable=\"false\" data-raw-code=\"class User:\n    def __init__(self, age):\n        self._age = age\n\n    @property\n    def age(self):\n        return self._age\n\n    @age.setter\n    def age(sel"}]},"hypothesisId":"A,E","runId":"post-fix"}
