{"timestamp":1782138179760,"sessionId":"ce29c0","location":"content-editor.js:savePage:before-repair","message":"blocks before repair","data":{"sectionId":"dataclass","blocks":[{"label":"dataclass","tag":"P","className":"","codeClass":"","textLen":9,"newlineCount":0,"outerSnippet":"<p><code>dataclass</code> 适合定义以数据为主的类，自动生成 <code>__init__</code>、<code>__repr__</code>、<code>__eq__</code> 等样板代码。</p>"},{"label":"dataclass","tag":"PRE","className":"","codeClass":"language-python hljs","textLen":128,"newlineCount":5,"outerSnippet":"<pre contenteditable=\"false\" data-raw-code=\"from dataclasses import dataclass, field\n\n@dataclass\nclass User:\n    name: str\n    tags: list[str] = field(default_factory=list)\" data-code-lang=\"python\"><c"}]},"hypothesisId":"A,E","runId":"post-fix"}
